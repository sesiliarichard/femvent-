{
    "name": "functions",
    "version": "1.0.0",
    "description": "Cloud Functions for KUZA Events App - Email Notifications",
    "main": "lib/index.js",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "20"
    },
    "dependencies": {
        "firebase-admin": "^12.0.0",
        "firebase-functions": "^5.0.0",
        "nodemailer": "^6.9.7",
        "qrcode": "^1.5.3"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/nodemailer": "^6.4.14",
        "@types/qrcode": "^1.5.5",
        "typescript": "^5.3.3"
    },
    "private": true
}