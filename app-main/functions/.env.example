# Email Configuration for Nodemailer
# Replace these values with your Gmail account details

# Your Gmail email address
EMAIL_USER=your-email@gmail.com

# Your Gmail App Password (NOT your regular password)
# To generate: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your-16-character-app-password

# Email sender name and address
EMAIL_FROM="KUZA Events <your-email@gmail.com>"
